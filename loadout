#!/usr/bin/env bash
# Main CLI entry point

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOADOUT_ROOT="$SCRIPT_DIR"

# Load logger for error messages
source "$LOADOUT_ROOT/core/lib/logger.sh"

# Usage
usage() {
    cat <<EOF
Usage: loadout <command> [options]

A declarative environment management system.

Available commands:
  apply <profile>    Apply a loadout profile
  plan  <profile>    Show what apply would do (no changes made)
  migrate            Migrate state/profile keys to current schema

Options:
  plan --verbose     Also list noop (already up-to-date) features

Examples:
  loadout apply profiles/wsl.yaml
  loadout plan  profiles/wsl.yaml
  loadout plan  profiles/wsl.yaml --verbose
  loadout migrate --dry-run

EOF
    exit 1
}

# Parse command
if [[ $# -lt 1 ]]; then
    usage
fi

COMMAND="$1"
shift

# Dispatch to command implementation
case "$COMMAND" in
    apply)
        exec "$LOADOUT_ROOT/cmd/apply.sh" "$@"
        ;;
    plan)
        exec "$LOADOUT_ROOT/cmd/plan.sh" "$@"
        ;;
    migrate)
        exec "$LOADOUT_ROOT/cmd/migrate.sh" "$@"
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        log_error "Unknown command: $COMMAND"
        echo ""
        usage
        ;;
esac
